IDR_MAINFRAME MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New Demo Context\tCtrl+N",   ID_FILE_NEW
        MENUITEM "New Abstract Context",        ID_FILE_EMPTYCONTEXT
        MENUITEM "&Open .avb Binary Context...\tCtrl+O", ID_FILE_OPEN
        MENUITEM "&Save .avb Binary Context\tCtrl+S", ID_FILE_SAVE
        MENUITEM "Save As...",                  ID_FILE_SAVE_AS
        MENUITEM "Export context as .cpp File", ID_EXPORTCFILE
        MENUITEM "Export Executable",           ID_EXPORTEXEC
        MENUITEM SEPARATOR
        MENUITEM "Recent Files",                ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "&Quit",                       ID_APP_EXIT
    END
    POPUP "&Display"
    BEGIN
        MENUITEM "&Tool Bar",                   ID_VIEW_TOOLBAR
        MENUITEM "&State Bar",                  ID_VIEW_STATUS_BAR
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About BassVeda GUI",         ID_APP_ABOUT
    END
END

