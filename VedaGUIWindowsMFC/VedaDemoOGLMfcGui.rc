FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
    PUSHBUTTON      "Validate",IDC_BUTTON1,1,17,64,15
    EDITTEXT        IDC_StringCtrl,65,1,210,131,ES_MULTILINE | 
                    ES_AUTOVSCROLL | ES_AUTOHSCROLL | ES_WANTRETURN | 
                    WS_VSCROLL | WS_HSCROLL,WS_EX_LEFTSCROLLBAR
    CTEXT           "-",IDC_MEMBERNAME,0,4,62,8
END

IDD_DIALOG1 DIALOGEX 0, 0, 39, 13
STYLE DS_SETFONT | DS_FIXEDSYS | WS_CHILD | WS_SYSMENU
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    EDITTEXT        IDC_EDITDLG1,0,0,32,13,ES_AUTOHSCROLL
END


