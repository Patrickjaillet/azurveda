        MENUITEM "Edit Preview",                ID_MEDITPreview
        MENUITEM "Edit Previous",               ID_MEDITB1
        MENUITEM SEPARATOR
        MENUITEM "Clone Object",                ID_BASEOBJECT_CLONE
        MENUITEM SEPARATOR
        MENUITEM "Destroy Object",              ID_BASEOBJECT_DESTROY
        MENUITEM "Destroy Independants",        ID_BASEOBJECT_DESTROYINDEPENDANT

    END
END

