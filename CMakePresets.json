{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-x64",
      "displayName": "Windows x64 (MSVC, vcpkg)",
      "description": "Generator name is a forward-looking guess ('Visual Studio 18 2026', following the 15=2017/16=2019/17=2022 numbering) since VS2026 was unreleased as of this port. Check `cmake -G` output on your machine and adjust if the installed IDE reports a different generator string.",
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-x64-lgpl",
      "displayName": "Windows x64 (LGPL modules only)",
      "inherits": "windows-x64",
      "cacheVariables": {
        "AZURVEDA_BUILD_GPL_MODULES": "OFF"
      }
    },
    {
      "name": "ci-windows-x64",
      "displayName": "CI: Windows x64 (Ninja, MSVC from PATH)",
      "description": "Generator-agnostic preset used by GitHub Actions; avoids hardcoding a Visual Studio IDE version so CI does not depend on which VS toolset happens to be preinstalled on the runner image.",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "AZURVEDA_BUILD_MFC_EDITOR": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-lgpl-release",
      "configurePreset": "windows-x64-lgpl",
      "configuration": "Release"
    },
    {
      "name": "ci-windows-x64-release",
      "configurePreset": "ci-windows-x64",
      "configuration": "Release"
    },
    {
      "name": "ci-windows-x64-debug",
      "configurePreset": "ci-windows-x64",
      "configuration": "Debug"
    }
  ]
}
